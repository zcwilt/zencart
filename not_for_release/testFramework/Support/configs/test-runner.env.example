# Optional shell-runner overrides for local parallel test commands.
# Copy to one of these untracked files and edit for your environment:
# - not_for_release/testFramework/Support/configs/test-runner.env
# - not_for_release/testFramework/Support/configs/test-runner.local.env

ZC_TEST_DB_HOST=db
ZC_TEST_DB_PORT=3306
ZC_TEST_DB_USER=root
ZC_TEST_DB_PASSWORD=root

# Enable when feature tests should send mail through a local SMTP catcher such as Mailpit.
# DDEV Mailpit defaults are host=mailpit and port=1025 from inside the web/test container.
ZC_TEST_USE_MAILSERVER=false
ZC_TEST_MAILSERVER_HOST=mailpit
ZC_TEST_MAILSERVER_PORT=1025
ZC_TEST_MAILSERVER_USER=ddev
ZC_TEST_MAILSERVER_PASSWORD=mailpit
